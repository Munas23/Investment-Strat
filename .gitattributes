# Normalize line endings.
# Stored as LF in the repo; checked out native on each OS.
# This stops Windows CRLF from showing every file as "modified".
* text=auto

# Explicit text types
*.py    text
*.md    text
*.txt   text
*.csv   text
*.json  text
*.cfg   text
*.ini   text
*.toml  text
*.yml   text
*.yaml  text

# Binary types (never touch line endings)
*.pkl   binary
*.pickle binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
*.xlsx  binary
*.xls   binary
*.parquet binary
